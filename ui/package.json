{
  "name": "pointer-mk18-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "cd ../kernel && zig build -Doptimize=ReleaseFast -p ..",
    "start": "npm run build:wasm && dotnet fable watch ../App.fsproj --outDir src-gen -e .js --run vite",
    "build:fs": "dotnet fable ../App.fsproj --outDir src-gen -e .js",
    "build": "npm run build:wasm && dotnet fable ../App.fsproj --outDir src-gen -e .js && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@carbon/icons": "^11.78.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.42.1",
    "codemirror": "^6.0.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
